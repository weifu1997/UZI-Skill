# Tushare HTTP Proxy Configuration
# ===================================
#
# Instructions:
# 1. Copy this file to .env (remove .example)
# 2. Fill in your actual values
# 3. .env file will not be committed to Git (in .gitignore)

# Tushare HTTP Proxy URL (Required)
# Example: http://api.example.com or http://localhost:8000
TUSHARE_HTTP_URL=http://your-api-url.com

# Tushare HTTP Proxy TOKEN (Optional)
# Fill this if your proxy requires authentication
TUSHARE_HTTP_TOKEN=your_token_here

# Optional: Custom Provider Priority
# ===================================
# Uncomment and customize if needed

# Financial data priority
# UZI_PROVIDERS_FINANCIALS=tushare_http,akshare

# K-line data priority
# UZI_PROVIDERS_KLINE=tushare_http,akshare

# Valuation data priority
# UZI_PROVIDERS_VALUATION=tushare_http,akshare

# Other API Keys (if using mx-* skills)
# ===================================
# MX_APIKEY=your_mx_apikey
